# Private key tài khoản mặc định của Anvil (chỉ dùng cho local)
PRIVATE_KEY=

# Private key ví MetaMask (dùng cho testnet/mainnet)
WALLET_PRIVATE_KEY=

# RPC URL cho mạng cục bộ Anvil
RPC_URL=http://127.0.0.1:8545

# RPC URL cho zkSync local
ZKSYNC_RPC_URL=http://127.0.0.1:8011

# RPC URL cho Sepolia testnet (Alchemy hoặc Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<YOUR_ALCHEMY_API_KEY>

# RPC URL cho zkSync Sepolia testnet
ZKSYNC_SEPOLIA_RPC_URL=https://zksync-sepolia.g.alchemy.com/v2/<YOUR_ALCHEMY_API_KEY>

# Alchemy API key
API_KEY=<YOUR_ALCHEMY_API_KEY>

# Etherscan API key (dùng để verify contract trên Sepolia)
SEPOLIA_API_KEY=<YOUR_ETHERSCAN_API_KEY>
